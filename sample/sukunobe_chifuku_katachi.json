  "notes": [
    { "category": "L字断面", "content": "地覆はL字断面（壁部160×513mm＋底版部660×270mm）。壁部と底版部の型枠は一体で組む。壁部外面(CA)と内面(CB)は対面セパ突き通し（セパ長160mm）。底版端面(CC)は別途セパ（長さ500mm）で固定。" },
    { "category": "断面寸法", "content": "図面No.18（地覆一般図）断面図・床版部 S=1:20。壁部幅160mm・高さ513mm（上端60mm+本体453mm）。底版部幅660mm×厚270mm。壁部は底版の道路側端部に位置する。" },
    { "category": "シール材", "content": "シール材10×10mm ポリサルファイド系。鋼製型枠上端部（壁部天端と鋼桁上フランジの取合い部）に設置。延長66m（両側合計）。見積参考資料に10m当り単価で計上。" },
    { "category": "含浸材", "content": "シラン系表面含浸材塗布。見積参考資料では50m2以上200m2未満の区分で176m2計上。地覆外面+底版端面の合計面積に対応。型枠面はケレン仕上げで含浸材の付着を確保。" },
    { "category": "コンクリート", "content": "RC-4S（膨張材入り・低添加型20kg/m3）。設計日打設量10〜100m3区分。一般養生。圧送管延長60m以下。膨張材はひび割れ抑制目的。" },
    { "category": "鉄筋", "content": "SD345 D13 エポキシ樹脂塗装鉄筋0.74t。鉄筋記号C1〜C4（図面No.18）。重ね長さ40d。鉄筋間隔150mm。鉄筋加工図は参考図No.4を参照。" },
    { "category": "端材転用", "content": "CA・CB面のコンパネカット（900→513mm）で端材387mm発生。CC面の高さ270mmに転用可能（387mm→270mmカット、残117mm廃棄）。コンパネ約18枚分の端材転用が可能。" },
    { "category": "見積との照合", "content": "見積参考資料の型枠面積57m2に対し、本計算42.77m2（片側3面合計）。差分14.23m2はL字内部段差面・端部小口型枠・目地部型枠等の可能性。佐々木現場代理人と要確認。" },
    { "category": "ひび割れ誘発目地", "content": "特記仕様書（総則19）に「地覆工のひび割れ誘発目地は設計変更で計上」と明記。目地位置・間隔は監督職員との協議事項。型枠のパネル割付は目地確定後に再調整が必要になる可能性あり。" },
    { "category": "壁高欄", "content": "壁高欄は別途工事（宿野辺改良工事、7月下旬以降）で施工。本工事では地覆のみ。壁高欄施工時のアンカーボルト差し筋等の処理については監督職員と協議のこと。" }
  ]
}
